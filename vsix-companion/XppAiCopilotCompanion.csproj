<Project ToolsVersion="15.0" DefaultTargets="Build" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <Import Project="Version.props" />
  <Import Project="$(MSBuildExtensionsPath)\$(MSBuildToolsVersion)\Microsoft.Common.props"
          Condition="Exists('$(MSBuildExtensionsPath)\$(MSBuildToolsVersion)\Microsoft.Common.props')" />

  <PropertyGroup>
    <Configuration Condition=" '$(Configuration)' == '' ">Debug</Configuration>
    <Platform Condition=" '$(Platform)' == '' ">AnyCPU</Platform>
    <MinimumVisualStudioVersion>17.0</MinimumVisualStudioVersion>
    <VSToolsPath Condition="'$(VSToolsPath)' == ''">$(MSBuildExtensionsPath32)\Microsoft\VisualStudio\v$(VisualStudioVersion)</VSToolsPath>
    <ProjectGuid>{b8e3f1a0-7c24-4d5b-9e1f-2a3b4c5d6e7f}</ProjectGuid>
    <ProjectTypeGuids>{82b43b9b-a64c-4715-b499-d71e9ca2bd60};{FAE04EC0-301F-11D3-BF4B-00C04F79EFBC}</ProjectTypeGuids>
    <OutputType>Library</OutputType>
    <RootNamespace>XppAiCopilotCompanion</RootNamespace>
    <AssemblyName>XppAiCopilotCompanion</AssemblyName>
    <TargetFrameworkVersion>v4.8</TargetFrameworkVersion>
    <LangVersion>latest</LangVersion>
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
    <GeneratePkgDefFile>true</GeneratePkgDefFile>
    <UseCodebase>true</UseCodebase>
    <IncludeAssemblyInVSIXContainer>true</IncludeAssemblyInVSIXContainer>
    <IncludeDebugSymbolsInVSIXContainer>true</IncludeDebugSymbolsInVSIXContainer>
    <IncludeDebugSymbolsInLocalVSIXDeployment>true</IncludeDebugSymbolsInLocalVSIXDeployment>
    <CopyBuildOutputToOutputDirectory>true</CopyBuildOutputToOutputDirectory>
  </PropertyGroup>

  <PropertyGroup Condition=" '$(Configuration)|$(Platform)' == 'Debug|AnyCPU' ">
    <DebugSymbols>true</DebugSymbols>
    <DebugType>full</DebugType>
    <Optimize>false</Optimize>
    <OutputPath>bin\Debug\</OutputPath>
    <DefineConstants>DEBUG;TRACE</DefineConstants>
    <PlatformTarget>AnyCPU</PlatformTarget>
    <CreateVsixContainer>true</CreateVsixContainer>
    <DeployExtension>false</DeployExtension>
  </PropertyGroup>

  <PropertyGroup Condition=" '$(Configuration)|$(Platform)' == 'Release|AnyCPU' ">
    <DebugType>pdbonly</DebugType>
    <Optimize>true</Optimize>
    <OutputPath>bin\Release\</OutputPath>
    <DefineConstants>TRACE</DefineConstants>
    <CreateVsixContainer>true</CreateVsixContainer>
  </PropertyGroup>

  <ItemGroup>
    <Compile Include="**\*.cs" Exclude="mcp-server\**\*.cs;obj\**\*.cs" />
  </ItemGroup>

  <ItemGroup>
    <EmbeddedResource Include="Resources\XppCopilotSystemPrompt.txt">
      <LogicalName>XppAiCopilotCompanion.XppCopilotSystemPrompt.txt</LogicalName>
    </EmbeddedResource>
  </ItemGroup>

  <ItemGroup>
    <Content Include="Resources\Icon.png">
      <IncludeInVSIX>true</IncludeInVSIX>
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
    <Content Include="mcp-server\bin\$(Configuration)\XppMcpServer.exe">
      <IncludeInVSIX>true</IncludeInVSIX>
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <Link>XppMcpServer.exe</Link>
    </Content>
  </ItemGroup>

  <ItemGroup>
    <None Include="source.extension.vsixmanifest" />
    <VSCTCompile Include="XppCopilotCommands.vsct">
      <ResourceName>Menus.ctmenu</ResourceName>
    </VSCTCompile>
  </ItemGroup>

  <!-- .NET Framework references -->
  <ItemGroup>
    <Reference Include="PresentationCore" />
    <Reference Include="PresentationFramework" />
    <Reference Include="System" />
    <Reference Include="System.ComponentModel.Composition" />
    <Reference Include="System.Design" />
    <Reference Include="System.Net" />
    <Reference Include="System.Net.Http" />
    <Reference Include="System.Runtime.Serialization" />
    <Reference Include="System.Xml" />
    <Reference Include="WindowsBase" />
  </ItemGroup>

  <!-- D365FO MetaModel APIs — compile-time refs from extracted MS VSIX.
       At runtime these DLLs are loaded by the MS D365FO tools VSIX in VS.
       Private=false means do NOT copy to output / ship in our VSIX. -->
  <ItemGroup>
    <Reference Include="Microsoft.Dynamics.AX.Metadata">
      <HintPath>Samples\Microsoft.Dynamics.FinOps.ToolsVS2022\Microsoft.Dynamics.AX.Metadata.dll</HintPath>
      <Private>false</Private>
    </Reference>
    <Reference Include="Microsoft.Dynamics.AX.Metadata.Core">
      <HintPath>Samples\Microsoft.Dynamics.FinOps.ToolsVS2022\Microsoft.Dynamics.AX.Metadata.Core.dll</HintPath>
      <Private>false</Private>
    </Reference>
    <Reference Include="Microsoft.Dynamics.AX.Metadata.Storage">
      <HintPath>Samples\Microsoft.Dynamics.FinOps.ToolsVS2022\Microsoft.Dynamics.AX.Metadata.Storage.dll</HintPath>
      <Private>false</Private>
    </Reference>
    <Reference Include="Microsoft.Dynamics.Framework.Tools.MetaModel.Core.17.0">
      <HintPath>Samples\Microsoft.Dynamics.FinOps.ToolsVS2022\Microsoft.Dynamics.Framework.Tools.MetaModel.Core.17.0.dll</HintPath>
      <Private>false</Private>
    </Reference>
    <Reference Include="Microsoft.Dynamics.Framework.Tools.Core.17.0">
      <HintPath>Samples\Microsoft.Dynamics.FinOps.ToolsVS2022\Microsoft.Dynamics.Framework.Tools.Core.17.0.dll</HintPath>
      <Private>false</Private>
    </Reference>
    <Reference Include="Microsoft.Dynamics.Framework.Tools.ProjectSystem.17.0">
      <HintPath>Samples\Microsoft.Dynamics.FinOps.ToolsVS2022\Microsoft.Dynamics.Framework.Tools.ProjectSystem.17.0.dll</HintPath>
      <Private>false</Private>
    </Reference>
    <Reference Include="Microsoft.Dynamics.Framework.Tools.ProjectSupport.17.0">
      <HintPath>Samples\Microsoft.Dynamics.FinOps.ToolsVS2022\Microsoft.Dynamics.Framework.Tools.ProjectSupport.17.0.dll</HintPath>
      <Private>false</Private>
    </Reference>
    <Reference Include="Microsoft.Dynamics.Framework.Tools.LabelEditor.17.0">
      <HintPath>Samples\Microsoft.Dynamics.FinOps.ToolsVS2022\Microsoft.Dynamics.Framework.Tools.LabelEditor.17.0.dll</HintPath>
      <Private>false</Private>
    </Reference>
    <Reference Include="Microsoft.Dynamics.Framework.Tools.Extensibility.17.0">
      <HintPath>Samples\Microsoft.Dynamics.FinOps.ToolsVS2022\Microsoft.Dynamics.Framework.Tools.Extensibility.17.0.dll</HintPath>
      <Private>false</Private>
    </Reference>
  </ItemGroup>

  <!-- VS SDK NuGet packages -->
  <ItemGroup>
    <PackageReference Include="Microsoft.VisualStudio.SDK" Version="17.0.32112.339" ExcludeAssets="runtime" />
    <PackageReference Include="Microsoft.VSSDK.BuildTools" Version="17.9.3184" />
  </ItemGroup>

  <Import Project="$(MSBuildToolsPath)\Microsoft.CSharp.targets" />
  <Import Project="$(VSToolsPath)\VSSDK\Microsoft.VsSDK.targets"
          Condition="'$(VSToolsPath)' != '' AND Exists('$(VSToolsPath)\VSSDK\Microsoft.VsSDK.targets')" />

  <!-- Always bump patch version for every build invocation, including direct MSBuild -->
  <Target Name="RunAutoVersion" BeforeTargets="CoreCompile" Condition="'$(DisableAutoVersion)' != 'true'">
    <Exec Command="powershell -NoProfile -ExecutionPolicy Bypass -File &quot;$(MSBuildProjectDirectory)\auto-version.ps1&quot; -AlwaysBumpPatch" />

    <!-- Re-load updated version values from Version.props in the same MSBuild process -->
    <XmlPeek XmlInputPath="$(MSBuildProjectDirectory)\Version.props"
             Query="/*[local-name()='Project']/*[local-name()='PropertyGroup']/*[local-name()='VersionMajor']/text()">
      <Output TaskParameter="Result" PropertyName="VersionMajor" />
    </XmlPeek>
    <XmlPeek XmlInputPath="$(MSBuildProjectDirectory)\Version.props"
             Query="/*[local-name()='Project']/*[local-name()='PropertyGroup']/*[local-name()='VersionMinor']/text()">
      <Output TaskParameter="Result" PropertyName="VersionMinor" />
    </XmlPeek>
    <XmlPeek XmlInputPath="$(MSBuildProjectDirectory)\Version.props"
             Query="/*[local-name()='Project']/*[local-name()='PropertyGroup']/*[local-name()='VersionPatch']/text()">
      <Output TaskParameter="Result" PropertyName="VersionPatch" />
    </XmlPeek>

    <PropertyGroup>
      <ExtensionVersion>$(VersionMajor).$(VersionMinor).$(VersionPatch)</ExtensionVersion>
      <AssemblyVersion>$(VersionMajor).$(VersionMinor).$(VersionPatch).0</AssemblyVersion>
      <FileVersion>$(VersionMajor).$(VersionMinor).$(VersionPatch).0</FileVersion>
      <InformationalVersion>$(ExtensionVersion)</InformationalVersion>
    </PropertyGroup>
  </Target>

  <!-- Build the MCP server before the main project so its exe is available for VSIX packaging -->
  <Target Name="BuildMcpServer" BeforeTargets="CoreCompile" DependsOnTargets="RunAutoVersion">
    <MSBuild Projects="$(MSBuildProjectDirectory)\mcp-server\XppMcpServer.csproj"
             Targets="Build"
             Properties="Configuration=$(Configuration)" />
  </Target>

  <!-- ============================================================
       Auto-version: stamp assembly + VSIX manifest from Version.props
       ============================================================ -->

  <!-- 1. Generate a VersionInfo.g.cs so the assembly gets the right attributes -->
  <Target Name="GenerateVersionInfo" BeforeTargets="CoreCompile">
    <PropertyGroup>
      <_VersionInfoFile>$(IntermediateOutputPath)VersionInfo.g.cs</_VersionInfoFile>
    </PropertyGroup>
    <ItemGroup>
      <Compile Include="$(_VersionInfoFile)" Condition="Exists('$(_VersionInfoFile)')" />
    </ItemGroup>
    <WriteLinesToFile File="$(_VersionInfoFile)" Overwrite="true" Lines="
// &lt;auto-generated&gt; Generated by MSBuild — do not edit. &lt;/auto-generated&gt;
using System.Reflection%3B
[assembly: AssemblyVersion(&quot;$(AssemblyVersion)&quot;)]
[assembly: AssemblyFileVersion(&quot;$(FileVersion)&quot;)]
[assembly: AssemblyInformationalVersion(&quot;$(InformationalVersion)&quot;)]
" />
    <ItemGroup>
      <Compile Include="$(_VersionInfoFile)" Condition="!Exists('$(_VersionInfoFile)')" />
    </ItemGroup>
  </Target>

  <!-- 2. Stamp the VSIX manifest Version attribute before the VSSDK reads it -->
  <Target Name="StampVsixVersion" BeforeTargets="GetVsixSourceItems;CreateVsixManifest" DependsOnTargets="GenerateVersionInfo">
    <PropertyGroup>
      <_ManifestPath>$(MSBuildProjectDirectory)\source.extension.vsixmanifest</_ManifestPath>
    </PropertyGroup>
    <XmlPoke XmlInputPath="$(_ManifestPath)"
             Namespaces="&lt;Namespace Prefix='v' Uri='http://schemas.microsoft.com/developer/vsx-schema/2011' /&gt;"
             Query="/v:PackageManifest/v:Metadata/v:Identity/@Version"
             Value="$(ExtensionVersion)" />
  </Target>

  <!-- 3. Force-sync and stamp intermediate manifest used for VSIX packaging -->
  <Target Name="SyncIntermediateVsixManifest" BeforeTargets="CreateVsixContainer" DependsOnTargets="StampVsixVersion">
    <PropertyGroup>
      <_ManifestPath>$(MSBuildProjectDirectory)\source.extension.vsixmanifest</_ManifestPath>
      <_IntermediateManifestPath>$(IntermediateOutputPath)extension.vsixmanifest</_IntermediateManifestPath>
    </PropertyGroup>

    <Copy SourceFiles="$(_ManifestPath)"
          DestinationFiles="$(_IntermediateManifestPath)"
          SkipUnchangedFiles="false" />

    <XmlPoke XmlInputPath="$(_IntermediateManifestPath)"
             Namespaces="&lt;Namespace Prefix='v' Uri='http://schemas.microsoft.com/developer/vsx-schema/2011' /&gt;"
             Query="/v:PackageManifest/v:Metadata/v:Identity/@Version"
             Value="$(ExtensionVersion)" />
  </Target>

  <!-- 4. Copy VSIX with versioned filename after packaging -->
  <Target Name="CopyVersionedVsix" AfterTargets="CreateVsixContainer">
    <PropertyGroup>
      <_SourceVsix>$(TargetVsixContainer)</_SourceVsix>
      <_VersionedVsix>$(OutDir)XppAiCopilotCompanion-$(ExtensionVersion).vsix</_VersionedVsix>
    </PropertyGroup>
    <Copy SourceFiles="$(_SourceVsix)"
          DestinationFiles="$(_VersionedVsix)"
          SkipUnchangedFiles="false" />
    <Message Text="Versioned VSIX: $(_VersionedVsix)" Importance="high" />
  </Target>

</Project>
